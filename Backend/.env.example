# Copy this to .env and fill in values

PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/telegram_award
JWT_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=your_google_client_id_here
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Brevo Transactional Email Settings
BREVO_API_KEY=your_brevo_api_key_here
BREVO_EMAIL_SENDER_NAME="Telegram Award"
BREVO_EMAIL_SENDER_EMAIL=your_verified_sender_email_here

# Enable mock OTP verification for local testing (uses code 123456)
MOCK_OTP=true

# AI Integration — Gemini (leave empty to use rule-based fallback)
# Get your key at: https://aistudio.google.com/app/apikey
AI_API_KEY=
